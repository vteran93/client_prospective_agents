# ── LLM — AWS Bedrock (primario) ───────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_DEFAULT_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# ── LLM — OpenAI (fallback) ────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Search APIs ────────────────────────────────────────────────────
# Tavily: https://app.tavily.com  (1k búsquedas/mes gratis)
TAVILY_API_KEY=tvly-...

# Brave: https://api.search.brave.com  (2k búsquedas/mes gratis)
BRAVE_API_KEY=BSA...

# DuckDuckGo: sin API key requerida (solo agrega "duckduckgo" a sources en YAML)

# SearXNG self-hosted (opcional):
# SEARXNG_BASE_URL=http://localhost:8080

# ── Google Maps ────────────────────────────────────────────────────
# Habilitar: Places API (New) en Google Cloud Console
GOOGLE_MAPS_API_KEY=AIza...

# ── Runtime overrides (opcionales, también configurables en YAML) ──
# LLM_PROVIDER=bedrock        # bedrock | openai
# LLM_TEMPERATURE=0.2
